{
  "kind": "collectionType",
  "collectionName": "spaces",
  "info": {
    "singularName": "space",
    "pluralName": "spaces",
    "displayName": "Space"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "Desk",
        "MeetingRoom"
      ]
    },
    "facility": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::facility.facility",
      "inversedBy": "spaces"
    },
    "reservations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::reservation.reservation",
      "mappedBy": "space"
    }
  }
}
